<!DOCTYPE html>
<html lang="en" class="h-full">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Create Account</title>

    <!-- Tailwind CDN -->
    <script src="https://cdn.tailwindcss.com"></script>

    <!-- Custom CSS -->
    <link rel="stylesheet" href="/styles/singup.css">
</head>
<body class="h-full bg-slate-100 flex items-center justify-center font-sans">

    <div class="w-full max-w-md bg-white rounded-2xl shadow-xl p-8 space-y-6">
        <!-- Header -->
        <div class="text-center">
            <h1 class="text-3xl font-bold text-gray-900">Create Account</h1>
            <p class="text-gray-500">Start your productivity journey</p>
        </div>

        <% if (typeof errorMsg !=="undefined" ) { %>
            <div class="text-center py-4 lg:px-4">
                <div class="p-2 bg-red-400 items-center text-black-100 leading-none lg:rounded-full flex lg:inline-flex"
                    role="alert">
                    <span class="flex rounded-full bg-red-500 uppercase px-2 py-1 text-sm font-bold mr-3 shadow-2xl">Error</span>
                    <span class="font-semibold mr-2 text-left flex-auto">
                        <%= errorMsg %>
                    </span>
                    <svg class="fill-current opacity-75 h-4 w-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20">
                        <path d="M12.95 10.707l.707-.707L8 4.343 6.586 5.757 10.828 10l-4.242 4.243L8 15.657l4.95-4.95z" />
                    </svg>
                </div>
            </div>
        <% } %>

        <!-- Form -->
        <form id="signupForm" action="/signup" method="POST" class="space-y-5">

            <!-- Full Name -->
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Full Name</label>
                <input type="text" name="fullName" required
                    class="input-field" placeholder="Your name">
            </div>

            <!-- Email -->
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Email</label>
                <input type="email" name="email" required
                    class="input-field" placeholder="you@example.com">
            </div>

            <!-- Password -->
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Password</label>
                <input type="password" id="password" name="password" required
                    class="input-field" placeholder="Enter strong password">
                <p id="passwordError" class="error-text hidden"></p>
            </div>

            <!-- Confirm Password -->
            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Confirm Password</label>
                <input type="password" id="confirmPassword" name="password_confirm" required
                    class="input-field" placeholder="Re-enter password">
                <p id="confirmError" class="error-text hidden"></p>
            </div>

            <!-- Terms -->
            <div class="flex items-start gap-2 text-sm">
                <input type="checkbox" name="i_agree" required class="mt-1">
                <span>I agree to Terms & Privacy Policy</span>
            </div>

            <!-- Submit -->
            <button type="submit" class="btn-primary">
                Create Account
            </button>

        </form>

        <!-- Footer -->
        <p class="text-center text-sm text-gray-500">
            Already have an account?
            <a href="/login" class="text-blue-600 hover:underline">Sign in</a>
        </p>

    </div>

    <script src="scripts/singup.js"></script>
</body>
</html>