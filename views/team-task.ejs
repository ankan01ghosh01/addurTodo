<!DOCTYPE html>
<html lang="en" class="light">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Team Tasks</title>

<script src="https://cdn.tailwindcss.com"></script>
<link rel="icon" href="/images/addtodo.png" type="image/x-icon">
<!-- Icons -->
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" rel="stylesheet" />

<style>
    body {
        font-family: system-ui, sans-serif;
    }
</style>
</head>

<body class="bg-gradient-to-br from-slate-100 to-slate-200 min-h-screen p-6">

<div class="max-w-3xl mx-auto">

    <!-- HEADER -->
    <div class="flex justify-between items-center mb-6">

        <h1 class="text-3xl font-bold text-slate-800 tracking-tight">
            Team Tasks
        </h1>

        <!-- Notification -->
        <div class="relative">

            <button id="notifBtn"
                class="relative p-2 rounded-full hover:bg-white shadow-sm transition">

                <span class="material-symbols-outlined text-slate-700">
                    notifications
                </span>

                <% if (notifications && notifications.length > 0) { %>
                <span class="absolute top-0 right-0 bg-red-500 text-white text-xs w-5 h-5 flex items-center justify-center rounded-full animate-pulse">
                    <%= notifications.length %>
                </span>
                <% } %>
            </button>

            <!-- Dropdown -->
            <div id="notifDropdown"
                class="hidden absolute right-0 mt-3 w-80 bg-white rounded-2xl shadow-xl p-4 space-y-3 z-50 transition-all duration-200">

                <div class="flex justify-between items-center border-b pb-2">
                    <span class="font-semibold text-sm">Notifications</span>

                    <% if (role) { %>
                    <button onclick="clearNotifications('<%= teamId %>')"
                        class="text-xs text-red-500 hover:text-red-600">
                        Clear
                    </button>
                    <% } %>
                </div>

                <% if (notifications && notifications.length > 0) { %>

                    <% notifications.forEach(n => { %>
                    <div class="text-sm text-gray-700 bg-slate-50 p-2 rounded-lg hover:bg-slate-100 transition">
                        🔔 <%= n.message %>
                    </div>
                    <% }) %>

                <% } else { %>
                    <p class="text-sm text-gray-400 text-center py-4">
                        No notifications
                    </p>
                <% } %>

            </div>
        </div>
    </div>

    <!-- ADD TASK -->
    <% if (role === 'admin') { %>
    <form action="/team/<%= teamId %>/add" method="POST"
        class="bg-white p-4 rounded-2xl shadow-md mb-6 flex gap-3">

        <input type="text" name="task" required
            placeholder="Write a new task..."
            class="flex-grow px-4 py-2 border border-slate-300 rounded-xl focus:ring-2 focus:ring-blue-400 outline-none transition">

        <button type="submit"
            class="bg-blue-600 hover:bg-blue-700 text-white px-5 py-2 rounded-xl shadow-sm transition active:scale-95">
            Add
        </button>

    </form>
    <% } %>

    <!-- TASK LIST -->
    <div class="space-y-3">

        <% if (tasks && tasks.length > 0) { %>

            <% tasks.forEach(task => { %>

            <div class="group flex items-center bg-white p-4 rounded-2xl shadow-sm hover:shadow-md transition">

                <!-- Checkbox -->
                <form action="/team/<%= teamId %>/complete/<%= task.id %>" method="POST">
                    <input type="checkbox"
                        onchange="this.form.submit()"
                        class="w-5 h-5 accent-blue-600 cursor-pointer"
                        <%= task.is_completed ? 'checked' : '' %>>
                </form>

                <!-- Text -->
                <div class="ml-4 flex-grow text-sm font-medium transition
                    <%= task.is_completed ? 'line-through text-gray-400' : 'text-gray-800' %>">
                    <%= task.task %>
                </div>

                <!-- Status -->
                <span class="text-xs px-3 py-1 rounded-full font-medium
                    <%= task.is_completed 
                        ? 'bg-green-100 text-green-600' 
                        : 'bg-yellow-100 text-yellow-600' %>">
                    <%= task.is_completed ? 'Done' : 'Pending' %>
                </span>

            </div>

            <% }) %>

        <% } else { %>

            <div class="bg-white p-6 rounded-2xl shadow text-center text-gray-400">
                No tasks yet
            </div>

        <% } %>

    </div>

</div>



<!-- SCRIPT -->
<script>
const btn = document.getElementById("notifBtn");
const dropdown = document.getElementById("notifDropdown");

btn.addEventListener("click", () => {
    dropdown.classList.toggle("hidden");
});

// Close on outside click
document.addEventListener("click", (e) => {
    if (!btn.contains(e.target) && !dropdown.contains(e.target)) {
        dropdown.classList.add("hidden");
    }
});

async function clearNotifications(teamId) {
    if (!confirm("Clear all notifications?")) return;

    await fetch(`/team/${teamId}/notifications/clear`, {
        method: "POST"
    });

    dropdown.innerHTML = `
        <div class="text-sm text-gray-400 text-center py-4">
            No notifications
        </div>
    `;
}
</script>

</body>
</html>
